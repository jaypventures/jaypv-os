{
  "scripts": {
    "build": "next build",
    "jpv:enforce": "node ./scripts/jpv-enforce.mjs",
    "jpv:enforce:test": "node ./scripts/jpv-enforce.mjs --test",
    "enforce:brand": "ts-node operations/jpv_os_enforcement/cli.ts jaypventures_llc --file",
    "dev": "next dev",
    "build:site": "next build",
    "build:worker": "npx wrangler deploy --dry-run --outdir /tmp/worker-build --config wix/bookings/wrangler.toml --env production",
    "deploy": "opennextjs-cloudflare deploy",
    "start": "next start",
    "lint": "eslint apps/ components/ operations/ pages/ tests/ --ext .ts,.tsx,.js,.jsx,.mdx",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "deploy:dryrun:bookings": "npx wrangler deploy --dry-run --outdir /tmp/worker-build --config wix/bookings/wrangler.toml --env production",
    "deploy:dryrun:entitlement": "npx wrangler deploy --dry-run --outdir /tmp/entitlement-build --config operations/entitlement-system/wrangler.toml",
    "deploy:dryrun:website": "npx wrangler deploy --dry-run --outdir /tmp/website-build --config apps/flagship-site/wrangler.toml",
    "validate:deploy:bookings": "node scripts/validate-deploy-config.mjs wix/bookings/wrangler.toml",
    "validate:deploy:entitlement": "node scripts/validate-deploy-config.mjs operations/entitlement-system/wrangler.toml",
    "validate:deploy:website": "node scripts/validate-deploy-config.mjs apps/flagship-site/wrangler.toml",
    "governance:freeze-check": "node scripts/governance/check-deployment-freeze.mjs",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "cfbuild": "opennextjs-cloudflare build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260504.1",
    "@eslint/js": "^9.39.4",
    "@opennextjs/cloudflare": "^1.19.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.2",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-istanbul": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "js-yaml": "^4.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.90.0"
  },
  "dependencies": {
    "hono": "^4.12.18",
    "next": "^16.2.6",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "webpack": "^5.106.2"
  },
  "name": "jaypv-os"
}
