{
  "env": {
    "es2021": true,
    "node": true,
    "worker": true,
    "serviceworker": true
  },
  "globals": {
    "KVNamespace": "readonly",
    "Request": "readonly",
    "Response": "readonly",
    "URL": "readonly",
    "ExecutionContext": "readonly"
  },
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:react/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [
    "@typescript-eslint",
    "react"
  ],
  "rules": {
    "@typescript-eslint/no-unused-vars": ["warn"],
    "react/prop-types": "off"
  },
  "settings": {
    "react": {
      "version": "detect"
    }
  }
}
